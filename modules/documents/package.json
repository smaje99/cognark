{
  "name": "@cognark/module-documents",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./domain/*": {
      "types": "./dist/domain/*.d.ts",
      "default": "./dist/domain/*.js"
    },
    "./application/*": {
      "types": "./dist/application/*.d.ts",
      "default": "./dist/application/*.js"
    },
    "./ports/*": {
      "types": "./dist/ports/*.d.ts",
      "default": "./dist/ports/*.js"
    },
    "./adapters/*": {
      "types": "./dist/adapters/*.d.ts",
      "default": "./dist/adapters/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "lint": "biome lint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cognark/module-persistence": "workspace:*",
    "@cognark/module-workspace": "workspace:*",
    "yaml": "2.8.3"
  }
}
